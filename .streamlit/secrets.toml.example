# 复制此文件为 secrets.toml 并填入你的真实 key
# Streamlit Cloud 部署时直接在 Web 控制台的 Secrets 配置即可

# DeepSeek API
DEEPSEEK_API_KEY = "sk-d5cb7e637081427b887bfd6f14552413"
DEEPSEEK_BASE_URL = "https://api.deepseek.com/v1"

# 简单密码门（防止陌生人访问消耗你的 API 额度）
APP_PASSWORD = "your_password_here"

# GitHub Gist 多设备同步（可选，留空则只用本地存储）
# 1. https://github.com/settings/tokens 创建 Personal Access Token，勾选 "gist" 权限
# 2. 创建一个 secret gist（可空内容），把 gist id 填到 GIST_ID
GITHUB_TOKEN = ""
GIST_ID = ""
